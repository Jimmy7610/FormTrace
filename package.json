{
  "name": "formtrace",
  "version": "1.2.0",
  "description": "FormTrace helps developers, QA testers and support teams understand why forms fail — directly in the browser.",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "typecheck": "tsc --noEmit",
    "prepare": "wxt prepare || true",
    "dom:check": "node tools/dom-check.mjs",
    "analyzer:check": "tsx tools/analyzer-check.ts",
    "report:check": "tsx tools/report-normalization-check.ts",
    "debug:check": "tsx tools/debug-marker-check.ts",
    "github:check": "tsx tools/github-issue-report-check.ts",
    "jira:check": "tsx tools/jira-report-check.ts",
    "history:check": "tsx tools/history-storage-check.ts",
    "persistent:check": "tsx tools/persistent-window-check.ts",
    "sidepanel:check": "tsx tools/sidepanel-check.ts",
    "sidepanel:ux-check": "tsx tools/sidepanel-ux-check.ts",
    "session:check": "tsx tools/session-state-check.ts",
    "css:blame-check": "tsx tools/css-blame-check.ts",
    "framework:check": "tsx tools/framework-demo-check.ts",
    "scroll:ux-check": "tsx tools/scroll-ux-check.ts",
    "build:check": "node tools/build-output-check.mjs",
    "demo": "http-server demo-pages -p 4173 -c-1",
    "verify": "npm run typecheck && npm run build && npm run dom:check && npm run analyzer:check && npm run report:check && npm run debug:check && npm run github:check && npm run jira:check && npm run history:check && npm run persistent:check && npm run sidepanel:check && npm run sidepanel:ux-check && npm run scroll:ux-check && npm run session:check && npm run css:blame-check && npm run framework:check && npm run build:check",
    "release:check": "npm run verify"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@webext-core/fake-browser": "^1.4.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "vite-tsconfig-paths": "^6.1.1",
    "wxt": "^0.19.29"
  }
}
